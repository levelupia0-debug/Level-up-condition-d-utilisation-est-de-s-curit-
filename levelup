<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Accès Système • Récupération</title>
    <style>
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: #fafafa;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* --- TERMINAL HACKER --- */
        #terminal-screen {
            background-color: #0c0c0c;
            width: 100%;
            height: 100vh;
            color: #00ff41;
            font-family: 'Courier New', Courier, monospace;
            padding: 20px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            justify-content: flex-start;
        }

        .command-line { margin-bottom: 10px; }
        .cursor { display: inline-block; width: 10px; height: 18px; background: #00ff41; animation: blink 1s infinite; }
        @keyframes blink { 0%, 50% { opacity: 1; } 51%, 100% { opacity: 0; } }
        
        #terminal-input {
            background: transparent;
            border: none;
            color: #00ff41;
            font-family: inherit;
            font-size: 16px;
            outline: none;
            width: 80%;
        }

        #code-display {
            font-size: 12px;
            line-height: 1.2;
            white-space: pre-wrap;
            overflow-y: hidden;
            flex-grow: 1;
        }

        .progress-container { width: 100%; border: 1px solid #00ff41; height: 20px; margin-top: 10px; display: none; }
        .progress-bar { width: 0%; height: 100%; background: #00ff41; transition: width 0.1s; }

        /* --- CONTENEUR GLOBAL --- */
        .container {
            background-color: #fff;
            border: 1px solid #dbdbdb;
            padding: 40px 30px;
            width: 100%;
            max-width: 350px;
            text-align: center;
            box-sizing: border-box;
            display: none;
        }
        .container.active { display: block; }

        /* --- STYLE INSTAGRAM --- */
        h1 { font-size: 24px; font-weight: bold; margin-bottom: 15px; color: #262626; }
        p { font-size: 14px; color: #8e8e8e; margin-bottom: 20px; }
        
        .profile-display {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            border: 1px solid #dbdbdb;
            margin: 0 auto 15px;
            overflow: hidden;
            background-color: #efefef;
            position: relative;
        }
        
        .profile-display img { width: 100%; height: 100%; object-fit: cover; }
        .username-text { font-weight: 600; font-size: 18px; margin-bottom: 20px; color: #262626; }

        input[type="password"] {
            width: 100%;
            padding: 10px;
            border: 1px solid #dbdbdb;
            border-radius: 3px;
            background-color: #fafafa;
            box-sizing: border-box;
            margin-bottom: 15px;
        }

        button {
            width: 100%;
            padding: 10px;
            background-color: #0095f6;
            color: white;
            border: none;
            border-radius: 4px;
            font-weight: 600;
            cursor: pointer;
        }

        /* --- CROPPER STYLES --- */
        .crop-container {
            width: 200px;
            height: 200px;
            border-radius: 50%;
            border: 2px dashed #dbdbdb;
            margin: 20px auto;
            overflow: hidden;
            position: relative;
            background: #fafafa;
            cursor: move;
        }
        #profile-preview { position: absolute; cursor: grab; display: none; transform-origin: center; }
        .zoom-controls { margin-bottom: 20px; }
        
        .hidden { display: none !important; }
    </style>
</head>
<body>

    <!-- SECTION 1: LE TERMINAL -->
    <div id="terminal-screen">
        <div id="output">
            <div class="command-line">root@system:~# INITIALIZING_HACK_V3...</div>
            <div class="command-line">root@system:~# ENTER_TARGET_USERNAME: <input type="text" id="terminal-input" autofocus autocomplete="off"></div>
        </div>
        <div id="code-display"></div>
        <div class="progress-container" id="progress-box">
            <div class="progress-bar" id="progress-bar"></div>
        </div>
        <button id="terminal-ok-btn" class="hidden" style="background:#00ff41; color:#000; margin-top:20px; width:auto; padding: 10px 40px;">OK</button>
    </div>

    <!-- SECTION 2: AJUSTEMENT PHOTO -->
    <div id="photo-screen" class="container">
        <h1>Photo de profil</h1>
        <p>Ajustez votre photo de profil librement.</p>
        <div class="crop-container" id="crop-area">
            <img id="profile-preview" src="" alt="Aperçu">
            <div id="no-photo-text" style="color:#ccc; padding-top: 80px;">Aucune photo</div>
        </div>
        <div class="zoom-controls">
            <input type="range" id="zoom-slider" min="0.1" max="4" step="0.01" value="1" style="width: 80%;">
        </div>
        <input type="file" id="file-input" accept="image/*" class="hidden">
        <button onclick="document.getElementById('file-input').click()" style="background:#efefef; color:#262626; margin-bottom:10px;">Choisir photo</button>
        <button id="goto-final-btn">Continuer</button>
    </div>

    <!-- SECTION 3: RÉCUPÉRATION FINALE INSTAGRAM -->
    <div id="final-screen" class="container">
        <h1>Récupération</h1>
        <div class="profile-display" id="final-photo-container">
            <!-- La photo ajustée sera injectée ici -->
        </div>
        <div class="username-text" id="final-username">@utilisateur</div>
        <p>Veuillez choisir un nouveau mot de passe sécurisé pour votre compte.</p>
        <input type="password" placeholder="Nouveau mot de passe">
        <button onclick="alert('Mot de passe mis à jour !')">Réinitialiser le mot de passe</button>
    </div>

<script>
    // --- VARIABLES D'ÉTAT ---
    let username = "";
    let photoData = { src: "", x: 0, y: 0, scale: 1 };
    
    // --- LOGIQUE TERMINAL ---
    const termInput = document.getElementById('terminal-input');
    const codeDisplay = document.getElementById('code-display');
    const progressBox = document.getElementById('progress-box');
    const progressBar = document.getElementById('progress-bar');
    const terminalBtn = document.getElementById('terminal-ok-btn');

    termInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter' && this.value.trim() !== "") {
            username = this.value;
            this.disabled = true;
            startHacking();
        }
    });

    function startHacking() {
        progressBox.style.display = 'block';
        const lines = [
            "CONNECTING TO INSTA_SERVER_X99...", "BYPASSING FIREWALL...", "ACCESSING DATABASE...",
            "ENCRYPTING SQL_INJECTION...", "DECRYPTING USER_DATA...", "FETCHING RSA_KEYS...",
            "HANDSHAKE SUCCESSFUL", "EXTRACTING PROFILE_INFO...", "PAYLOAD DELIVERED."
        ];
        
        let i = 0;
        let progress = 0;
        
        const interval = setInterval(() => {
            // Ajouter du code aléatoire
            const randomCode = Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
            codeDisplay.innerHTML += `<div>${lines[i % lines.length]} - ${randomCode}</div>`;
            codeDisplay.scrollTop = codeDisplay.scrollHeight;
            
            progress += 1.5;
            progressBar.style.width = progress + "%";
            
            if (progress >= 100) {
                clearInterval(interval);
                terminalBtn.classList.remove('hidden');
            }
            i++;
        }, 50);
    }

    terminalBtn.addEventListener('click', () => {
        document.getElementById('terminal-screen').style.display = 'none';
        document.getElementById('photo-screen').classList.add('active');
    });

    // --- LOGIQUE PHOTO (CROPPER) ---
    const fileInput = document.getElementById('file-input');
    const preview = document.getElementById('profile-preview');
    const zoomSlider = document.getElementById('zoom-slider');
    const cropArea = document.getElementById('crop-area');
    const noPhotoText = document.getElementById('no-photo-text');

    let isDragging = false;
    let startX, startY;

    fileInput.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (event) => {
                preview.src = event.target.result;
                preview.style.display = 'block';
                noPhotoText.style.display = 'none';
                photoData.src = event.target.result;
                resetPhoto();
            };
            reader.readAsDataURL(file);
        }
    });

    function resetPhoto() {
        photoData.x = 0; photoData.y = 0; photoData.scale = 1;
        zoomSlider.value = 1;
        updateTransform();
    }

    function updateTransform() {
        preview.style.transform = `translate(${photoData.x}px, ${photoData.y}px) scale(${photoData.scale})`;
    }

    zoomSlider.addEventListener('input', (e) => {
        photoData.scale = e.target.value;
        updateTransform();
    });

    // Drag Logic
    const startDrag = (e) => {
        if(!preview.src) return;
        isDragging = true;
        const cX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        const cY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
        startX = cX - photoData.x;
        startY = cY - photoData.y;
    };
    const doDrag = (e) => {
        if(!isDragging) return;
        const cX = e.type.includes('touch') ? e.touches[0].clientX : e.clientX;
        const cY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
        photoData.x = cX - startX;
        photoData.y = cY - startY;
        updateTransform();
    };
    const endDrag = () => isDragging = false;

    cropArea.addEventListener('mousedown', startDrag);
    window.addEventListener('mousemove', doDrag);
    window.addEventListener('mouseup', endDrag);
    cropArea.addEventListener('touchstart', startDrag);
    window.addEventListener('touchmove', doDrag);
    window.addEventListener('touchend', endDrag);

    // --- LOGIQUE FINALE ---
    const gotoFinalBtn = document.getElementById('goto-final-btn');
    const finalScreen = document.getElementById('final-screen');
    const finalPhotoContainer = document.getElementById('final-photo-container');
    const finalUsername = document.getElementById('final-username');

    gotoFinalBtn.addEventListener('click', () => {
        // On prépare l'interface finale
        finalUsername.innerText = "@" + username;
        
        // On clone la preview pour garder le cadrage (visual-only pour la démo)
        const finalImg = preview.cloneNode();
        finalImg.style.position = 'absolute';
        finalImg.style.width = '100%'; 
        finalImg.style.height = 'auto';
        
        // On vide et on remplit le cercle final
        finalPhotoContainer.innerHTML = "";
        finalPhotoContainer.appendChild(finalImg);
        
        document.getElementById('photo-screen').classList.remove('active');
        finalScreen.classList.add('active');
    });

</script>
</body>
</html>
