rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. VÉRIFICATION DE CLÉ : 
    match /{path=**}/security/{docId} {
      allow read: if request.auth != null; 
    }

    // 2. CONFIGURATION SYSTÈME :
    match /artifacts/level-ia-premium/system/config {
      allow read: if request.auth != null; 
    }

    // 3. DONNÉES UTILISATEUR (Historique privé) :
    match /artifacts/level-ia-premium/users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null; 
    }
    
    // 4. NOUVEAU - DONNÉES PUBLIQUES (ADMIN DASHBOARD) :
    // Permet aux utilisateurs d'envoyer des avis/bugs et au Dashboard de fonctionner
    match /artifacts/level-ia-premium/public/data/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 5. SÉCURITÉ GLOBALE :
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
